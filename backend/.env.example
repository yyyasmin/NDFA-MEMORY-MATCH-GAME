# Copy this file to .env and set your real PostgreSQL password.
# PostgreSQL connection (user:password@host:port/database)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ndfa_memory_game

# Optional: allow frontend origin (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional
PORT=5000
SECRET_KEY=your-secret-key
