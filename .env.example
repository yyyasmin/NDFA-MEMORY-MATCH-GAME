# Frontend: which backend to use. Copy to .env.local (gitignored) for local dev.
#
# Option A – Switch (easiest for local dev):
#   Render backend:  VITE_USE_RENDER_BACKEND=true
#   Local backend:  VITE_USE_RENDER_BACKEND=false   (backend must run on http://localhost:5000)
#
# Option B – Explicit URL (overrides the switch):
#   VITE_BACKEND_URL=http://localhost:5000
#   or
#   VITE_BACKEND_URL=https://ndfa-memory-match-game.onrender.com
#
# Netlify: set VITE_BACKEND_URL or VITE_USE_RENDER_BACKEND in Site → Environment variables, then redeploy.
VITE_USE_RENDER_BACKEND=true
